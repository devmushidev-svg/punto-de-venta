# Copiar a .env y ajustar. Nunca commitear .env con secretos reales.

# Base de datos PostgreSQL (Supabase). Tomar de Supabase > Project Settings > Database > Connection string.
# Para servidor persistente (Railway/Render) usar el "Session pooler" (puerto 5432).
DATABASE_URL="postgresql://postgres.PROYECTO:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# Obligatorio en produccion: cadena larga y aleatoria.
JWT_SECRET="dev-secret-local-change-me"

# Origenes del front permitidos (coma separada). En produccion: el dominio de Vercel.
# CORS_ORIGINS=https://tu-app.vercel.app,http://localhost:5173

# URL publica de esta API (para construir el enlace del logo en PDFs/ticket).
# API_PUBLIC_URL=https://tu-api.up.railway.app

# Supabase storage/sync (opcional, para sincronizacion entre dispositivos).
# SUPABASE_URL=https://tu-proyecto.supabase.co
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_STORAGE_BUCKET=punto-flow
# SUPABASE_SYNC_TABLE=punto_sync_events

# Intentos de login fallidos por IP en ventana de 15 min (por defecto 12)
# LOGIN_RATE_MAX_FAILS=12

# NODE_ENV=production
# PORT=3001
