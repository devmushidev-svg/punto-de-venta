# Copiar a .env y ajustar. Nunca commitear .env con secretos reales.

# Base local embebida para Windows/offline. El cliente NO instala PostgreSQL.
DATABASE_URL="file:./dev.db"

# Obligatorio en produccion: cadena larga y aleatoria.
JWT_SECRET="dev-secret-local-change-me"

# Supabase nube administrada. Supabase usa PostgreSQL internamente, pero el cliente no lo instala.
# La API local usa SERVICE_ROLE solo del lado servidor para sincronizar.
# SUPABASE_URL=https://tu-proyecto.supabase.co
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_STORAGE_BUCKET=punto-flow
# SUPABASE_SYNC_TABLE=punto_sync_events

# Identidad opcional de instalacion local. Se usa para registrar caja/dispositivo y sync.
# DEVICE_CODE=CAJA-01
# DEVICE_NAME=Caja principal
# BRANCH_CODE=PRIN

# Origenes del front (coma separada). Por defecto localhost Vite.
# CORS_ORIGINS=https://tu-dominio.com,https://www.tu-dominio.com

# Intentos de login fallidos por IP en ventana de 15 min (por defecto 12)
# LOGIN_RATE_MAX_FAILS=12

# NODE_ENV=production
# PORT=3001

# ── Notificaciones por correo (Nodemailer) ────────────────────────────────
# Descomenta y rellena para activar los correos automáticos.
# Genera una "App Password" en: https://myaccount.google.com/apppasswords
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tu-correo@gmail.com
# SMTP_PASS=tu-app-password-de-16-caracteres
# SMTP_FROM=PuntoFlow <tu-correo@gmail.com>
# SMTP_NOTIFY=destino-notificaciones@gmail.com

# ── Diagnóstico con IA (OpenAI) ───────────────────────────────────────────
# Obtén tu clave en: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-proj-...
