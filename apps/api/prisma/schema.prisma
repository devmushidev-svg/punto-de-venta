generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Organization {
  id              String   @id @default(cuid())
  slug            String   @unique
  name            String
  slogan          String?
  taxId           String?
  phone           String?
  email           String?
  website         String?
  address         String?
  city            String?
  department      String?
  zip             String?
  recoveryEmail   String?
  country         String   @default("HN")
  currency        String   @default("HNL")
  currencySymbol  String   @default("L")
  language        String   @default("es")
  logoUrl         String?
  taxIdType       String?  @default("RTN")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  users           User[]
  products        Product[]
  customers       Customer[]
  suppliers       Supplier[]
  sales           Sale[]
  purchases       Purchase[]
  cashSessions    CashSession[]
  quotes          Quote[]
  supplierOrders  SupplierOrder[]
  settings        OrganizationSettings?
  stockLocations  StockLocation[]
  stockTransfers  StockTransfer[]
  stockAdjustments StockAdjustment[]
  employees       Employee[]
  expenses        Expense[]
  payrollPeriods  PayrollPeriod[]
}

model User {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  username       String
  passwordHash   String
  displayName    String
  role           String   @default("cajero")
  /// JSON: { "allow": [...], "deny": [...] } — claves: reports.view, inventory.transfers, accounts.receivable, accounts.payable, purchases.record
  permissionsJson String  @default("{}")
  /// Se incrementa al cambiar rol o permissionsJson; el JWT lleva copia para invalidar sesiones obsoletas.
  permissionsRev  Int     @default(0)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  cashSessions   CashSession[]
  sales          Sale[]
  purchases      Purchase[]
  stockTransfers StockTransfer[]
  stockAdjustments StockAdjustment[]
  expenses               Expense[]
  payrollPeriods         PayrollPeriod[]
  receivableSurcharges ReceivableSurcharge[]
  payableSurcharges    PayableSurcharge[]

  @@unique([organizationId, username])
}

/// Colaborador de la empresa (no confundir con usuario del sistema).
model Employee {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employeeCode   String?
  name           String
  idDocument     String?
  phone          String?
  email          String?
  position       String?
  hireDate       DateTime?
  active         Boolean  @default(true)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  payrollLines   PayrollLine[]

  @@unique([organizationId, employeeCode])
  @@index([organizationId])
}

model Expense {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  category       String
  amount         Float
  expenseDate    DateTime @default(now())
  notes          String?
  createdAt      DateTime @default(now())

  @@index([organizationId])
  @@index([expenseDate])
}

/// Planilla por mes (alcance mínimo: totales por empleado).
model PayrollPeriod {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  year           Int
  month          Int
  status         String   @default("BORRADOR")
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  lines          PayrollLine[]

  @@unique([organizationId, year, month])
  @@index([organizationId])
}

model PayrollLine {
  id               String                 @id @default(cuid())
  periodId         String
  period           PayrollPeriod          @relation(fields: [periodId], references: [id], onDelete: Cascade)
  employeeId       String
  employee         Employee               @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  gross            Float
  deductions       Float                  @default(0)
  net              Float
  notes            String?
  deductionItems   PayrollLineDeduction[]

  @@unique([periodId, employeeId])
}

/// Desglose de deducciones de una línea de planilla (IHSS, rap, préstamos, etc.).
model PayrollLineDeduction {
  id        String      @id @default(cuid())
  lineId    String
  line      PayrollLine @relation(fields: [lineId], references: [id], onDelete: Cascade)
  concept   String
  amount    Float
  sortOrder Int         @default(0)

  @@index([lineId])
}

model Product {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sku            String
  name           String
  description    String?
  unit           String   @default("UND")
  price          Float
  price2         Float?
  price3         Float?
  price4         Float?
  /// JSON: [{ "minQty": number, "price": number }, ...] — precio por volumen sobre la lista elegida
  volumePricesJson String  @default("[]")
  cost           Float    @default(0)
  taxPercent     Float    @default(0)
  taxName        String   @default("ISV")
  stock          Float    @default(0)
  minStock       Float    @default(0)
  category       String?
  barcode        String?
  quickCode      String?
  location       String?
  brand          String?
  imageUrl       String?
  productType    String   @default("PRODUCTO")
  esGranel       Boolean  @default(false)
  supplierId     String?
  supplier       Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  saleLines      SaleLine[]
  purchaseLines  PurchaseLine[]
  quoteLines     QuoteLine[]
  orderLines     SupplierOrderLine[]
  kitLines       ProductKitLine[] @relation("KitParent")
  componentOfKits ProductKitLine[] @relation("KitComponent")
  stockTransferLines StockTransferLine[]
  stockAdjustmentLines StockAdjustmentLine[]

  @@unique([organizationId, sku])
}

/// Ajuste manual de inventario (auditoría) con motivo y líneas por producto.
model StockAdjustment {
  id                 String   @id @default(cuid())
  organizationId     String
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  adjustmentNumber   String?
  userId             String
  user               User     @relation(fields: [userId], references: [id])
  reason             String
  notes              String?
  createdAt          DateTime @default(now())
  lines              StockAdjustmentLine[]

  @@index([organizationId])
}

model StockAdjustmentLine {
  id            String          @id @default(cuid())
  adjustmentId  String
  adjustment    StockAdjustment @relation(fields: [adjustmentId], references: [id], onDelete: Cascade)
  productId     String
  product       Product         @relation(fields: [productId], references: [id], onDelete: Restrict)
  qtyDelta      Float

  @@index([adjustmentId])
  @@index([productId])
}

model StockLocation {
  id               String   @id @default(cuid())
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  code             String
  name             String
  active           Boolean  @default(true)
  sortOrder        Int      @default(0)
  transfersFrom    StockTransfer[] @relation("TransferFromLoc")
  transfersTo      StockTransfer[] @relation("TransferToLoc")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([organizationId, code])
  @@index([organizationId])
}

model StockTransfer {
  id               String   @id @default(cuid())
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  transferNumber   String?
  fromLocationId   String
  fromLocation     StockLocation @relation("TransferFromLoc", fields: [fromLocationId], references: [id], onDelete: Restrict)
  toLocationId     String
  toLocation       StockLocation @relation("TransferToLoc", fields: [toLocationId], references: [id], onDelete: Restrict)
  status           String   @default("BORRADOR")
  notes            String?
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  createdAt        DateTime @default(now())
  sentAt           DateTime?
  receivedAt       DateTime?
  lines            StockTransferLine[]

  @@index([organizationId])
}

model StockTransferLine {
  id          String        @id @default(cuid())
  transferId  String
  transfer    StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  productId   String
  product     Product       @relation(fields: [productId], references: [id], onDelete: Restrict)
  qty         Float

  @@index([transferId])
}

/// Componentes de un producto tipo KIT (combo/paquete). Cantidad de cada componente por 1 unidad de kit.
model ProductKitLine {
  id                 String  @id @default(cuid())
  kitProductId       String
  kitProduct         Product @relation("KitParent", fields: [kitProductId], references: [id], onDelete: Cascade)
  componentProductId String
  component          Product @relation("KitComponent", fields: [componentProductId], references: [id], onDelete: Restrict)
  qty                Float

  @@unique([kitProductId, componentProductId])
  @@index([kitProductId])
  @@index([componentProductId])
}

model Customer {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  code           String   @default("0")
  name           String
  address        String?
  phone          String?
  taxId          String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  sales          Sale[]
  quotes         Quote[]

  @@index([organizationId])
}

model Supplier {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  phone          String?
  email          String?
  taxId          String?
  address        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  purchases      Purchase[]
  orders         SupplierOrder[]
  products       Product[]

  @@index([organizationId])
}

model Sale {
  id             String    @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoiceNumber  String?
  customerId     String?
  customer       Customer? @relation(fields: [customerId], references: [id])
  userId         String
  user           User      @relation(fields: [userId], references: [id])
  sellerName     String?
  terms          String    @default("CONTADO")
  status         String    @default("COMPLETADA")
  notes          String?
  priceTier      Int       @default(1)
  subtotal       Float
  tax            Float
  discount       Float     @default(0)
  total          Float
  paid           Float     @default(0)
  saleDate       DateTime  @default(now())
  dueDate        DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  lines                 SaleLine[]
  receivableSurcharges  ReceivableSurcharge[]

  @@index([organizationId])
}

/// Recargo sobre venta a crédito (aumenta lo que debe el cliente; no modifica líneas de la factura).
model ReceivableSurcharge {
  id        String   @id @default(cuid())
  saleId    String
  sale      Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  amount    Float
  note      String?
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@index([saleId])
}

model SaleLine {
  id              String  @id @default(cuid())
  saleId          String
  sale            Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId       String
  product         Product @relation(fields: [productId], references: [id])
  qty             Float
  unitPrice       Float
  discountPercent Float   @default(0)
  taxPercent      Float   @default(0)
  lineTotal       Float
}

model Purchase {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  supplierId     String?
  supplier       Supplier? @relation(fields: [supplierId], references: [id])
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  reference      String?
  terms          String   @default("CONTADO")
  subtotal       Float
  tax            Float
  total          Float
  paid           Float    @default(0)
  purchaseDate   DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  lines              PurchaseLine[]
  payableSurcharges  PayableSurcharge[]

  @@index([organizationId])
}

/// Recargo sobre compra a crédito (aumenta lo que debe la empresa al proveedor).
model PayableSurcharge {
  id         String   @id @default(cuid())
  purchaseId String
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  amount     Float
  note       String?
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  createdAt  DateTime @default(now())

  @@index([purchaseId])
}

model PurchaseLine {
  id          String   @id @default(cuid())
  purchaseId  String
  purchase    Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  qty         Float
  unitCost    Float
  taxPercent  Float    @default(0)
  lineTotal   Float
}

model CashSession {
  id             String    @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User      @relation(fields: [userId], references: [id])
  openedAt       DateTime  @default(now())
  closedAt       DateTime?
  openingCash    Float     @default(0)
  closingCash    Float?
  expectedCash   Float?
  notes          String?
}

model OrganizationSettings {
  id             String   @id @default(cuid())
  organizationId String   @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  generalJson    String   @default("{}")
  invoiceJson    String   @default("{}")
  updatedAt      DateTime @updatedAt
}

model Quote {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customerId     String?
  customer       Customer? @relation(fields: [customerId], references: [id])
  userId         String
  quoteNumber    String?
  status         String   @default("BORRADOR")
  validUntil     DateTime?
  subtotal       Float
  tax            Float
  total          Float
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  lines          QuoteLine[]

  @@index([organizationId])
}

model QuoteLine {
  id         String  @id @default(cuid())
  quoteId    String
  quote      Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  productId  String
  product    Product @relation(fields: [productId], references: [id])
  qty        Float
  unitPrice  Float
  taxPercent Float   @default(0)
  lineTotal  Float
}

model SupplierOrder {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  supplierId     String?
  supplier       Supplier? @relation(fields: [supplierId], references: [id])
  userId         String
  orderNumber    String?
  status         String   @default("PENDIENTE")
  expectedDate   DateTime?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  lines          SupplierOrderLine[]

  @@index([organizationId])
}

model SupplierOrderLine {
  id        String          @id @default(cuid())
  orderId   String
  order     SupplierOrder   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product         @relation(fields: [productId], references: [id])
  qty       Float
  unitPrice Float?
  notes     String?
}
