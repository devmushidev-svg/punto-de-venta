{
  "name": "@punto-flow/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:push": "prisma db push && node scripts/snapshot-schema.mjs",
    "db:seed": "tsx prisma/seed.ts",
    "db:snapshot-schema": "node scripts/snapshot-schema.mjs",
    "db:generate": "prisma generate",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@prisma/client": "^6.3.1",
    "bcryptjs": "^2.4.3",
    "exceljs": "^4.4.0",
    "hono": "^4.6.16",
    "jsonwebtoken": "^9.0.2",
    "pdfkit": "^0.18.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.5",
    "@types/pdfkit": "^0.17.5",
    "prisma": "^6.3.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
