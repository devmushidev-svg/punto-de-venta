{
  "name": "punto-flow",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm run dev -w apps/api\" \"npm run dev -w apps/web\"",
    "build": "npm run build -w apps/api && npm run build -w apps/web",
    "verify": "npm run build",
    "db:push": "npm run db:push -w apps/api",
    "db:seed": "npm run db:seed -w apps/api",
    "db:snapshot-schema": "npm run db:snapshot-schema -w apps/api",
    "windows:local": "powershell -ExecutionPolicy Bypass -File scripts/windows-local-start.ps1",
    "manual:extract": "node scripts/extract-manual-pdf.cjs"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "pdf-parse": "^1.1.1"
  }
}
