generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Organization {
  id             String                @id @default(cuid())
  slug           String                @unique
  name           String
  slogan         String?
  taxId          String?
  phone          String?
  email          String?
  website        String?
  address        String?
  city           String?
  department     String?
  zip            String?
  recoveryEmail  String?
  country        String                @default("HN")
  currency       String                @default("HNL")
  currencySymbol String                @default("L")
  language       String                @default("es")
  logoUrl        String?
  taxIdType      String?               @default("RTN")
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  users          User[]
  products       Product[]
  customers      Customer[]
  suppliers      Supplier[]
  sales          Sale[]
  purchases      Purchase[]
  cashSessions   CashSession[]
  quotes         Quote[]
  supplierOrders SupplierOrder[]
  settings       OrganizationSettings?
}

model User {
  id             String        @id @default(cuid())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  username       String
  passwordHash   String
  displayName    String
  role           String        @default("cajero")
  active         Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  cashSessions   CashSession[]
  sales          Sale[]

  @@unique([organizationId, username])
}

model Product {
  id             String              @id @default(cuid())
  organizationId String
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sku            String
  name           String
  description    String?
  unit           String              @default("UND")
  price          Float
  price2         Float?
  price3         Float?
  price4         Float?
  cost           Float               @default(0)
  taxPercent     Float               @default(0)
  taxName        String              @default("ISV")
  stock          Float               @default(0)
  minStock       Float               @default(0)
  category       String?
  barcode        String?
  quickCode      String?
  location       String?
  brand          String?
  imageUrl       String?
  productType    String              @default("PRODUCTO")
  esGranel       Boolean             @default(false)
  supplierId     String?
  supplier       Supplier?           @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  active         Boolean             @default(true)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  saleLines      SaleLine[]
  purchaseLines  PurchaseLine[]
  quoteLines     QuoteLine[]
  orderLines     SupplierOrderLine[]

  @@unique([organizationId, sku])
}

model Customer {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  code           String       @default("0")
  name           String
  address        String?
  phone          String?
  taxId          String?
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  sales          Sale[]
  quotes         Quote[]

  @@index([organizationId])
}

model Supplier {
  id             String          @id @default(cuid())
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  phone          String?
  email          String?
  taxId          String?
  address        String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  purchases      Purchase[]
  orders         SupplierOrder[]
  products       Product[]

  @@index([organizationId])
}

model Sale {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoiceNumber  String?
  customerId     String?
  customer       Customer?    @relation(fields: [customerId], references: [id])
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  sellerName     String?
  terms          String       @default("CONTADO")
  status         String       @default("COMPLETADA")
  notes          String?
  priceTier      Int          @default(1)
  subtotal       Float
  tax            Float
  discount       Float        @default(0)
  total          Float
  paid           Float        @default(0)
  saleDate       DateTime     @default(now())
  dueDate        DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  lines          SaleLine[]

  @@index([organizationId])
}

model SaleLine {
  id              String  @id @default(cuid())
  saleId          String
  sale            Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId       String
  product         Product @relation(fields: [productId], references: [id])
  qty             Float
  unitPrice       Float
  discountPercent Float   @default(0)
  taxPercent      Float   @default(0)
  lineTotal       Float
}

model Purchase {
  id             String         @id @default(cuid())
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  supplierId     String?
  supplier       Supplier?      @relation(fields: [supplierId], references: [id])
  userId         String
  reference      String?
  terms          String         @default("CONTADO")
  subtotal       Float
  tax            Float
  total          Float
  paid           Float          @default(0)
  purchaseDate   DateTime       @default(now())
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  lines          PurchaseLine[]

  @@index([organizationId])
}

model PurchaseLine {
  id         String   @id @default(cuid())
  purchaseId String
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  qty        Float
  unitCost   Float
  taxPercent Float    @default(0)
  lineTotal  Float
}

model CashSession {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  openedAt       DateTime     @default(now())
  closedAt       DateTime?
  openingCash    Float        @default(0)
  closingCash    Float?
  expectedCash   Float?
  notes          String?
}

model OrganizationSettings {
  id             String       @id @default(cuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  generalJson    String       @default("{}")
  invoiceJson    String       @default("{}")
  updatedAt      DateTime     @updatedAt
}

model Quote {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customerId     String?
  customer       Customer?    @relation(fields: [customerId], references: [id])
  userId         String
  quoteNumber    String?
  status         String       @default("BORRADOR")
  validUntil     DateTime?
  subtotal       Float
  tax            Float
  total          Float
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  lines          QuoteLine[]

  @@index([organizationId])
}

model QuoteLine {
  id         String  @id @default(cuid())
  quoteId    String
  quote      Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  productId  String
  product    Product @relation(fields: [productId], references: [id])
  qty        Float
  unitPrice  Float
  taxPercent Float   @default(0)
  lineTotal  Float
}

model SupplierOrder {
  id             String              @id @default(cuid())
  organizationId String
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  supplierId     String?
  supplier       Supplier?           @relation(fields: [supplierId], references: [id])
  userId         String
  orderNumber    String?
  status         String              @default("PENDIENTE")
  expectedDate   DateTime?
  notes          String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  lines          SupplierOrderLine[]

  @@index([organizationId])
}

model SupplierOrderLine {
  id        String        @id @default(cuid())
  orderId   String
  order     SupplierOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product       @relation(fields: [productId], references: [id])
  qty       Float
  unitPrice Float?
  notes     String?
}
